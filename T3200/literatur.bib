	keywords = {Computer Science - Machine Learning, Computer Science - Computer Vision and Pattern Recognition, Electrical Engineering and Systems Science - Image and Video Processing},
	file = {PDF:C\:\\Users\\Sven\\Zotero\\storage\\3NGZ3JB9\\Khader et al. - 2023 - Medical Diffusion Denoising Diffusion Probabilistic Models for 3D Medical Image Generation.pdf:application/pdf},
